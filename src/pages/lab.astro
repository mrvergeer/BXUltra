---
// src/pages/lab.astro
// BX Ultra — The Lab
// Structure: Nav → Hero → How it works strip → Filterable Library → Lab Notes → CTA → Footer
//
// HOW TO ADD CONTENT:
//   1. New study  → add an object to the `studies` array below
//   2. New post   → add an object to the `labNotes` array below
//   Both are plain data — no CMS, no database. Astro rebuilds the page on each deploy.
//
import Layout from '../layouts/Layout.astro';

// ── TOPIC TAGS — used for filter buttons and study cards ─────────────────────
// Add new tags here as your library grows. Keep them short.
const topics = [
  "All",
  "Exercise",
  "Airway Clearance",
  "Exacerbations",
  "Nutrition",
  "Diagnosis",
  "Treatment",
  "Mental Health",
  "Epidemiology",
];

// ── STUDY LIBRARY ────────────────────────────────────────────────────────────
// Add a new object here each time you add a study to the library.
// Fields:
//   id       — unique slug, used for anchor links
//   title    — full study title (keep it readable, not always verbatim)
//   authors  — first author et al.
//   year     — publication year (number)
//   journal  — journal name
//   topic    — must match one of the topics array above (except "All")
//   type     — "RCT" | "Meta-analysis" | "Review" | "Observational" | "Case Study" | "Guideline"
//   summary  — 1–2 sentence plain-language summary. Your words, not the abstract.
//   url      — DOI or PubMed link
//   keyFinding — single bold headline finding (shown on card front)
//   starred  — true = featured/landmark paper
const studies = [
  {
    id:          "spruit-2013-pulm-rehab",
    title:       "An Official American Thoracic Society/European Respiratory Society Statement: Key Concepts and Advances in Pulmonary Rehabilitation",
    authors:     "Spruit et al.",
    year:        2013,
    journal:     "American Journal of Respiratory and Critical Care Medicine",
    topic:       "Exercise",
    type:        "Guideline",
    summary:     "The landmark joint statement establishing pulmonary rehabilitation as a core intervention for chronic lung disease, including bronchiectasis. Covers exercise training, education, and behaviour change.",
    url:         "https://doi.org/10.1164/rccm.201309-1634ST",
    keyFinding:  "Pulmonary rehabilitation improves exercise capacity and quality of life in chronic lung disease.",
    starred:     true,
  },
  {
    id:          "lee-2021-exercise-bx",
    title:       "Exercise training for bronchiectasis",
    authors:     "Lee et al.",
    year:        2021,
    journal:     "Cochrane Database of Systematic Reviews",
    topic:       "Exercise",
    type:        "Meta-analysis",
    summary:     "Cochrane review of exercise training in bronchiectasis. Found meaningful improvements in exercise capacity and health-related quality of life. No serious adverse events reported.",
    url:         "https://doi.org/10.1002/14651858.CD013110.pub2",
    keyFinding:  "Exercise training significantly improves exercise capacity and quality of life in BX — with no serious adverse events.",
    starred:     true,
  },
  {
    id:          "mcdonnell-2021-act",
    title:       "Airway clearance techniques for bronchiectasis",
    authors:     "McDonnell et al.",
    year:        2021,
    journal:     "Cochrane Database of Systematic Reviews",
    topic:       "Airway Clearance",
    type:        "Meta-analysis",
    summary:     "Systematic review of airway clearance techniques (ACT) in bronchiectasis. Finds ACT improves quality of life and reduces sputum burden. No single technique proven superior for all patients.",
    url:         "https://doi.org/10.1002/14651858.CD008351.pub3",
    keyFinding:  "ACT improves QoL and reduces sputum — but no single technique works best for everyone.",
    starred:     false,
  },
  {
    id:          "chalmers-2023-guidelines",
    title:       "European Respiratory Society guidelines for the management of adult bronchiectasis",
    authors:     "Chalmers et al.",
    year:        2023,
    journal:     "European Respiratory Journal",
    topic:       "Treatment",
    type:        "Guideline",
    summary:     "The most current ERS clinical guidelines for bronchiectasis management. Covers diagnosis, airway clearance, antibiotic use, mucoactive therapy, and exercise. Essential reference.",
    url:         "https://doi.org/10.1183/13993003.00629-2023",
    keyFinding:  "Updated ERS guidelines recommend exercise and ACT as core management — antibiotics only when clearly indicated.",
    starred:     true,
  },
  {
    id:          "ni-2024-prevalence-meta",
    title:       "Prevalence of bronchiectasis in adults: a meta-analysis",
    authors:     "Ni et al.",
    year:        2024,
    journal:     "BMC Public Health",
    topic:       "Epidemiology",
    type:        "Meta-analysis",
    summary:     "First quantitative global synthesis of BX prevalence. Estimated at 680 per 100,000 adults — considerably higher than previously assumed, and likely an underestimate.",
    url:         "https://doi.org/10.1186/s12889-024-19956-y",
    keyFinding:  "Global adult prevalence estimated at ~680 per 100,000 — higher than most clinicians realise.",
    starred:     false,
  },
  {
    id:          "aksamit-2017-fatigue",
    title:       "Fatigue in patients with non-cystic fibrosis bronchiectasis",
    authors:     "Aksamit et al.",
    year:        2017,
    journal:     "Chest",
    topic:       "Mental Health",
    type:        "Observational",
    summary:     "Documents the significant burden of fatigue in non-CF bronchiectasis. Found fatigue is associated with worse quality of life independent of lung function — meaning it's not simply explained by airway obstruction.",
    url:         "https://doi.org/10.1016/j.chest.2017.01.019",
    keyFinding:  "Fatigue in BX is severe, underreported, and not fully explained by lung function alone.",
    starred:     false,
  },
  {
    id:          "finch-2015-exacerbation",
    title:       "Defining Exacerbations in Non-Cystic Fibrosis Bronchiectasis",
    authors:     "Finch et al.",
    year:        2015,
    journal:     "Chest",
    topic:       "Exacerbations",
    type:        "Review",
    summary:     "Reviews the definition, recognition, and impact of exacerbations in non-CF bronchiectasis. Highlights that early treatment of exacerbations is associated with better outcomes.",
    url:         "https://doi.org/10.1378/chest.14-1144",
    keyFinding:  "Earlier treatment of exacerbations leads to faster recovery and less cumulative damage.",
    starred:     false,
  },
  {
    id:          "quint-2016-bx-diagnosis",
    title:       "Changes in the incidence, prevalence and mortality of bronchiectasis in the UK from 2004 to 2013",
    authors:     "Quint et al.",
    year:        2016,
    journal:     "European Respiratory Journal",
    topic:       "Diagnosis",
    type:        "Observational",
    summary:     "Large UK population study showing a 40% increase in BX prevalence over 10 years. Demonstrates significant diagnostic delay and underdiagnosis, particularly in primary care.",
    url:         "https://doi.org/10.1183/13993003.00033-2015",
    keyFinding:  "BX prevalence rose 40% in a decade — largely due to improved detection, not true incidence increase.",
    starred:     false,
  },
];

// ── LAB NOTES (editorial blog posts) ─────────────────────────────────────────
// Add a new object here for each Lab Note post you write.
// Fields:
//   slug      — URL slug, e.g. "zone-2-and-bx"  → will be /lab/zone-2-and-bx
//   title     — post headline
//   date      — ISO date string "YYYY-MM-DD"
//   topic     — matches topics array
//   excerpt   — 1–2 sentence teaser shown on the card
//   readTime  — estimated read time in minutes
//   linked    — array of study IDs this post references (from studies array above)
//
// NOTE: These cards currently link to placeholder URLs.
// When you're ready to add actual blog posts, create src/pages/lab/[slug].astro
// and Astro will route them automatically. Ask for that template when you're ready.
const labNotes = [
  {
    slug:     "exercise-is-medicine-what-the-cochrane-review-means",
    title:    "Exercise is medicine: what the Cochrane review actually means for BX athletes",
    date:     "2025-06-01",
    topic:    "Exercise",
    excerpt:  "The 2021 Cochrane meta-analysis on exercise in bronchiectasis is one of the most important papers in the field. Here's what it says, what it doesn't say, and what it means if you're trying to train.",
    readTime: 6,
    linked:   ["lee-2021-exercise-bx"],
  },
  {
    slug:     "fatigue-the-symptom-nobody-talks-about",
    title:    "Fatigue: the BX symptom nobody talks about enough",
    date:     "2025-05-18",
    topic:    "Mental Health",
    excerpt:  "Breathlessness gets all the attention. But in my experience — and in the research — fatigue is the symptom that most shapes what a day with BX actually looks like.",
    readTime: 5,
    linked:   ["aksamit-2017-fatigue"],
  },
  {
    slug:     "ers-guidelines-2023-plain-language",
    title:    "The 2023 ERS guidelines decoded: what they actually recommend and why",
    date:     "2025-05-03",
    topic:    "Treatment",
    excerpt:  "The European Respiratory Society updated their BX management guidelines in 2023. I read the whole thing. Here's the plain-language version for people who actually live with this.",
    readTime: 9,
    linked:   ["chalmers-2023-guidelines"],
  },
];

// ── Helper: format date for display ──────────────────────────────────────────
function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}

// ── Study type colour mapping ────────────────────────────────────────────────
const typeColors: Record<string, string> = {
  "RCT":          "type-rct",
  "Meta-analysis":"type-meta",
  "Review":       "type-review",
  "Observational":"type-obs",
  "Case Study":   "type-case",
  "Guideline":    "type-guide",
};
---

<Layout
  title="The Lab"
  description="BX Ultra's research library — filterable studies, clinical guidelines, and editorial Lab Notes interpreting the latest science on bronchiectasis, exercise, and lung health."
>

  <!-- ══════════════════════════════════════════════════════════
       NAV
  ══════════════════════════════════════════════════════════ -->
  <header class="nav">
    <a href="/" class="logo" aria-label="BX Ultra home">BX<span>ULTRA</span></a>
    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
    <nav id="nav-menu" class="nav-menu" role="navigation" aria-label="Main">
      <a href="/engine-room">Engine Room</a>
      <a href="/lab" class="nav-active">The Lab</a>
      <a href="/lifestyle">Lifestyle Hub</a>
      <a href="/basecamp">Basecamp</a>
      <a href="/what-is-bx" class="nav-pill">What is BX?</a>
    </nav>
  </header>

  <!-- ══════════════════════════════════════════════════════════
       PAGE HERO
  ══════════════════════════════════════════════════════════ -->
  <section class="page-hero" aria-labelledby="lab-heading">
    <div class="container">
      <p class="page-eyebrow">Research · Evidence · Interpretation</p>
      <h1 id="lab-heading" class="page-headline">The <em>Lab</em></h1>
      <p class="page-sub">
        A curated library of bronchiectasis research — plus editorial notes
        interpreting what the science actually means for people who live with BX
        and train around it. Evidence first, always showing the work.
      </p>
      <div class="hero-meta">
        <span class="meta-pill">⚗ {studies.length} studies indexed</span>
        <span class="meta-pill">📝 {labNotes.length} Lab Notes</span>
        <span class="meta-pill">🔍 {topics.length - 1} topic filters</span>
      </div>
    </div>
    <div class="hero-rule" aria-hidden="true">
      <span class="rule-line"></span>
      <span class="rule-dot"></span>
      <span class="rule-line"></span>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       HOW IT WORKS STRIP
  ══════════════════════════════════════════════════════════ -->
  <div class="how-strip">
    <div class="container how-grid">
      <div class="how-item">
        <span class="how-num" aria-hidden="true">01</span>
        <div>
          <strong>The Library</strong>
          <p>Indexed studies with plain-language summaries. Filter by topic or study type. Each entry links to the original paper.</p>
        </div>
      </div>
      <div class="how-divider" aria-hidden="true"></div>
      <div class="how-item">
        <span class="how-num" aria-hidden="true">02</span>
        <div>
          <strong>Lab Notes</strong>
          <p>Editorial posts interpreting specific studies — what they mean, what they don't, and what they mean for BX athletes.</p>
        </div>
      </div>
      <div class="how-divider" aria-hidden="true"></div>
      <div class="how-item">
        <span class="how-num" aria-hidden="true">03</span>
        <div>
          <strong>Always cited</strong>
          <p>Every claim links to its source. This isn't opinion dressed up as science — the papers are always one click away.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       FEATURED / STARRED STUDIES
  ══════════════════════════════════════════════════════════ -->
  {studies.some(s => s.starred) && (
    <section class="featured-section" aria-labelledby="featured-heading">
      <div class="container">
        <p class="section-eyebrow">Landmark papers</p>
        <h2 id="featured-heading" class="section-title">Start here</h2>
        <div class="featured-grid">
          {studies.filter(s => s.starred).map(s => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              class="featured-card"
              aria-label={`${s.title} — opens in new tab`}
            >
              <div class="featured-card-top">
                <span class={`type-badge ${typeColors[s.type] ?? ''}`}>{s.type}</span>
                <span class="featured-star" aria-label="Landmark paper">★</span>
              </div>
              <span class="featured-topic">{s.topic}</span>
              <h3 class="featured-title">{s.title}</h3>
              <p class="featured-authors">{s.authors} · {s.journal} · {s.year}</p>
              <p class="featured-finding">{s.keyFinding}</p>
              <span class="featured-link">Read paper ↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════════════════════
       FULL LIBRARY — filterable
  ══════════════════════════════════════════════════════════ -->
  <section class="library-section" aria-labelledby="library-heading">
    <div class="container">
      <p class="section-eyebrow">All studies</p>
      <h2 id="library-heading" class="section-title">The Library</h2>

      <!-- Filter controls -->
      <div class="filter-bar" role="group" aria-label="Filter studies by topic">
        <span class="filter-label">Filter by topic:</span>
        <div class="filter-chips">
          {topics.map((t, i) => (
            <button
              class={`filter-btn${i === 0 ? ' filter-btn--active' : ''}`}
              data-topic={t}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {t}
            </button>
          ))}
        </div>
      </div>

      <!-- Study type legend -->
      <div class="type-legend" aria-label="Study type legend">
        <span class="type-badge type-rct">RCT</span>
        <span class="type-badge type-meta">Meta-analysis</span>
        <span class="type-badge type-review">Review</span>
        <span class="type-badge type-obs">Observational</span>
        <span class="type-badge type-case">Case Study</span>
        <span class="type-badge type-guide">Guideline</span>
      </div>

      <!-- Results count -->
      <p class="results-count" id="results-count" aria-live="polite">
        Showing {studies.length} of {studies.length} studies
      </p>

      <!-- Study cards grid -->
      <div class="library-grid" id="library-grid" role="list">
        {studies.map(s => (
          <article
            class="study-card"
            data-topic={s.topic}
            role="listitem"
            id={s.id}
          >
            <div class="study-card-header">
              <div class="study-card-badges">
                <span class={`type-badge ${typeColors[s.type] ?? ''}`}>{s.type}</span>
                {s.starred && <span class="star-badge" aria-label="Landmark paper">★ Landmark</span>}
              </div>
              <span class="study-year">{s.year}</span>
            </div>

            <span class="study-topic-tag">{s.topic}</span>
            <h3 class="study-title">{s.title}</h3>
            <p class="study-authors">{s.authors} · <em>{s.journal}</em></p>

            <div class="study-finding">
              <span class="finding-label" aria-hidden="true">Key finding</span>
              <p>{s.keyFinding}</p>
            </div>

            <p class="study-summary">{s.summary}</p>

            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              class="study-link"
              aria-label={`Read full paper: ${s.title}`}
            >
              Read paper ↗
            </a>
          </article>
        ))}
      </div>

      <!-- Empty state (shown by JS when no results) -->
      <div class="empty-state" id="empty-state" aria-live="polite" hidden>
        <p>No studies yet in this category.</p>
        <p>Check back soon — or <a href="/basecamp" class="inline-link">suggest a paper via Basecamp</a>.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       LAB NOTES
  ══════════════════════════════════════════════════════════ -->
  <section class="notes-section" aria-labelledby="notes-heading">
    <div class="container">
      <p class="section-eyebrow light">Editorial</p>
      <h2 id="notes-heading" class="section-title light">Lab Notes</h2>
      <p class="notes-intro">
        Interpretation, opinion, and plain-language breakdown of research that matters
        for BX athletes. Each note is anchored to specific studies in the library above.
      </p>

      <div class="notes-grid">
        {labNotes.map(note => (
          <article class="note-card">
            <div class="note-card-top">
              <span class="note-topic">{note.topic}</span>
              <span class="note-read">{note.readTime} min read</span>
            </div>
            <h3 class="note-title">
              <a href={`/lab/${note.slug}`} class="note-title-link">{note.title}</a>
            </h3>
            <p class="note-excerpt">{note.excerpt}</p>
            <div class="note-footer">
              <time class="note-date" datetime={note.date}>{formatDate(note.date)}</time>
              {note.linked.length > 0 && (
                <div class="note-linked" aria-label="Referenced studies">
                  {note.linked.map(id => {
                    const study = studies.find(s => s.id === id);
                    return study ? (
                      <a href={`#${id}`} class="note-linked-pill" title={study.title}>
                        ⚗ {study.authors.split(' ')[0]} {study.year}
                      </a>
                    ) : null;
                  })}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SUBMIT A STUDY CTA
  ══════════════════════════════════════════════════════════ -->
  <section class="submit-strip" aria-label="Suggest a study">
    <div class="container submit-inner">
      <div>
        <h2 class="submit-headline">Found a study we should index?</h2>
        <p class="submit-sub">
          The library grows with the community. If you've come across research
          that belongs here, share it in Basecamp.
        </p>
      </div>
      <a href="/basecamp" class="btn btn-primary">Go to Basecamp →</a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="BX Ultra home">BX<span>ULTRA</span></a>
        <p class="footer-tagline">Breathe. Push. Repeat.</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <a href="/engine-room">Engine Room</a>
        <a href="/lab">The Lab</a>
        <a href="/lifestyle">Lifestyle Hub</a>
        <a href="/basecamp">Basecamp</a>
        <a href="/what-is-bx">What is BX?</a>
        <a href="/about">About</a>
      </nav>
      <div class="footer-social">
        <a href="#" aria-label="Instagram" rel="noopener noreferrer">IG</a>
        <a href="#" aria-label="Discord"   rel="noopener noreferrer">DC</a>
        <a href="#" aria-label="Strava"    rel="noopener noreferrer">ST</a>
      </div>
    </div>
    <p class="footer-legal">
      © {new Date().getFullYear()} BX Ultra · Built by The Airway Adventurer
    </p>
  </footer>

</Layout>

<!-- ════════════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════════════ -->
<style>

  /* ── NAV ─────────────────────────────────────────────────── */
  .nav { position: sticky; top: 0; z-index: 100; background: var(--forest); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; height: 56px; }
  .logo { font-family: var(--font-display); font-weight: 900; font-size: 24px; letter-spacing: 0.03em; color: var(--cream); text-decoration: none; }
  .logo span { color: var(--orange); }
  .nav-menu { display: flex; align-items: center; gap: 1.5rem; }
  .nav-menu a { font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--cream80); text-decoration: none; transition: color 0.15s; }
  .nav-menu a:hover { color: var(--cream); }
  .nav-active { color: var(--cream) !important; border-bottom: 1.5px solid var(--orange); padding-bottom: 2px; }
  .nav-pill { background: var(--orange); color: var(--cream) !important; padding: 5px 12px; border-radius: var(--radius-sm); }
  .nav-toggle { display: none; flex-direction: column; justify-content: space-between; width: 22px; height: 16px; background: none; border: none; cursor: pointer; padding: 0; }
  .nav-toggle span { display: block; height: 2px; background: var(--cream); border-radius: 1px; }

  /* ── SHARED ──────────────────────────────────────────────── */
  .container { max-width: var(--max-w); margin: 0 auto; padding: 0 2rem; }
  .section-eyebrow { font-family: var(--font-display); font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--orange); margin-bottom: 0.4rem; }
  .section-eyebrow.light { color: rgba(230,92,0,0.9); }
  .section-title { font-family: var(--font-display); font-size: clamp(32px,4vw,44px); font-weight: 900; text-transform: uppercase; line-height: 0.95; color: var(--forest); margin-bottom: 2rem; }
  .section-title.light { color: var(--cream); }
  .inline-link { color: var(--orange); text-decoration: underline; text-underline-offset: 3px; font-weight: 500; }
  .inline-link:hover { opacity: 0.75; }
  .btn { display: inline-block; font-family: var(--font-display); font-size: 14px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; padding: 11px 22px; border-radius: var(--radius-sm); transition: opacity 0.15s, transform 0.1s; white-space: nowrap; }
  .btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .btn-primary { background: var(--orange); color: var(--cream); border: none; }

  /* ── PAGE HERO ───────────────────────────────────────────── */
  .page-hero { background: var(--forest); padding: 4.5rem 0 0; }
  .page-hero .container { padding-bottom: 2.5rem; }
  .page-eyebrow { font-family: var(--font-display); font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--orange); margin-bottom: 0.75rem; }
  .page-headline { font-family: var(--font-display); font-weight: 900; font-size: clamp(52px,8vw,80px); line-height: 0.93; text-transform: uppercase; letter-spacing: -0.01em; color: var(--cream); margin-bottom: 1.5rem; }
  .page-headline em { font-style: normal; color: var(--orange); }
  .page-sub { font-size: 16px; line-height: 1.65; color: var(--cream80); max-width: 520px; margin-bottom: 2rem; }
  .hero-meta { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .meta-pill { font-family: var(--font-display); font-size: 12px; font-weight: 600; letter-spacing: 0.06em; color: var(--cream80); background: var(--cream10); border: 1px solid var(--cream15); padding: 5px 14px; border-radius: 20px; }
  .hero-rule { display: flex; align-items: center; padding: 0 2rem; }
