---
// src/pages/index.astro
// BX Ultra homepage: Nav → Ticker → Hero → Pillars → Training Log preview → Tagline → Footer
import Layout from '../layouts/Layout.astro';

// ── Latest log entries ────────────────────────────────────────────────────────
// Replace these with real entries as you write them.
const logEntries = [
  { date: "Jun 1",  title: "June — Run at least 2 miles every day",               tag: "Run",      tagColor: "green"  },
  { date: "Jun 3",  title: "Morning physio + zone 2 cycling block",                tag: "Recovery", tagColor: "teal"   },
  { date: "May 28", title: "New study: airway clearance techniques in runners",     tag: "Lab",      tagColor: "orange" },
];

// ── Four pillar cards ─────────────────────────────────────────────────────────
const pillars = [
  {
    num: "01",
    label: "Inspiration",
    title: "The Engine Room",
    desc:  "Personal training logs, race reports, and real athletic data. Watching someone go from 0 to ultra — lungs and all — week by week.",
    href:  "/engine-room",
    cta:   "Training Logs",
  },
  {
    num: "02",
    label: "Science",
    title: "The Lab",
    desc:  "Clinical studies, new research, and expert insight. Everything worth knowing about bronchiectasis — from diagnosis to the frontier of treatment.",
    href:  "/lab",
    cta:   "Research",
  },
  {
    num: "03",
    label: "Daily life",
    title: "Lifestyle Hub",
    desc:  "Nutrition, hydration, air quality, sleep, and daily routines built around a lung condition. Small changes that add up to real energy.",
    href:  "/lifestyle",
    cta:   "Routines",
  },
  {
    num: "04",
    label: "Community",
    title: "Basecamp",
    desc:  "Discord, Strava, community spotlights. A place to find people who get it — and maybe train alongside them.",
    href:  "/basecamp",
    cta:   "Join",
  },
];

const tickerText = "BREATHE &nbsp;·&nbsp; PUSH &nbsp;·&nbsp; REPEAT &nbsp;·&nbsp; BRONCHIECTASIS DOESN'T FINISH YOU &nbsp;·&nbsp; IT JUST CHANGES THE STARTING LINE &nbsp;·&nbsp;";
---

<Layout title="Home">

  <!-- ══════════════════════════════════════════════════════════
       NAV
  ══════════════════════════════════════════════════════════ -->
  <header class="nav">
    <a href="/" class="logo" aria-label="BX Ultra home">
      BX<span>ULTRA</span>
    </a>

    <!-- Mobile hamburger (toggle handled by inline JS below) -->
    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    <nav id="nav-menu" class="nav-menu" role="navigation" aria-label="Main">
      <a href="/engine-room">Engine Room</a>
      <a href="/lab">The Lab</a>
      <a href="/lifestyle">Lifestyle Hub</a>
      <a href="/basecamp">Basecamp</a>
      <a href="/what-is-bx" class="nav-pill">What is BX?</a>
    </nav>
  </header>

  <!-- ══════════════════════════════════════════════════════════
       TICKER
  ══════════════════════════════════════════════════════════ -->
  <div class="ticker" role="marquee" aria-label="Site tagline">
    <div class="ticker-track" aria-hidden="true">
      <!-- Duplicated so the scroll is seamless -->
      <span set:html={tickerText} />
      <span set:html={tickerText} />
      <span set:html={tickerText} />
      <span set:html={tickerText} />
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════════════════ -->
  <section class="hero" aria-labelledby="hero-heading">

    <p class="hero-eyebrow">Bronchiectasis · Aspiring Athlete · Weekend Adventurer</p>

    <h1 id="hero-heading" class="hero-headline">
      The <em>lungs</em> they said<br>would slow you down
    </h1>

    <p class="hero-sub">
      One diagnosis. One decision to not let this be a slow down. Training logs,
      science, lifestyle tools, inspiration, and a community for people who refuse
      to let a chronic lung condition define their limits.
    </p>

    <div class="hero-ctas">
      <a href="/start-here" class="btn btn-primary">Start Here ↗</a>
      <a href="/what-is-bx"  class="btn btn-ghost">What is Bronchiectasis?</a>
    </div>

    <div class="hero-stats" aria-label="Key facts">
      <div class="stat">
        <span class="stat-val">41</span>
        <span class="stat-label">Age, starting fresh</span>
      </div>
      <div class="stat">
        <span class="stat-val">BX</span>
        <span class="stat-label">Diagnosed</span>
      </div>
      <div class="stat">
        <span class="stat-val">Ultra</span>
        <span class="stat-label">The goal</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       SECTION DIVIDER TICKER
  ══════════════════════════════════════════════════════════ -->
  <div class="divider-ticker" aria-hidden="true">
    <div class="ticker-track">
      <span>THE ENGINE ROOM &nbsp;·&nbsp; THE LAB &nbsp;·&nbsp; THE LIFESTYLE HUB &nbsp;·&nbsp; BASECAMP &nbsp;·&nbsp; </span>
      <span>THE ENGINE ROOM &nbsp;·&nbsp; THE LAB &nbsp;·&nbsp; THE LIFESTYLE HUB &nbsp;·&nbsp; BASECAMP &nbsp;·&nbsp; </span>
      <span>THE ENGINE ROOM &nbsp;·&nbsp; THE LAB &nbsp;·&nbsp; THE LIFESTYLE HUB &nbsp;·&nbsp; BASECAMP &nbsp;·&nbsp; </span>
      <span>THE ENGINE ROOM &nbsp;·&nbsp; THE LAB &nbsp;·&nbsp; THE LIFESTYLE HUB &nbsp;·&nbsp; BASECAMP &nbsp;·&nbsp; </span>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════
       FOUR PILLARS
  ══════════════════════════════════════════════════════════ -->
  <section class="pillars-section" aria-labelledby="pillars-heading">
    <div class="container">
      <p class="section-eyebrow">What's inside</p>
      <h2 id="pillars-heading" class="section-title">Four Pillars</h2>

      <div class="pillars-grid">
        {pillars.map((p) => (
          <article class="pillar-card">
            <div class="pillar-card-top">
              <span class="pillar-num">{p.num} / {p.label}</span>
              <h3 class="pillar-title">{p.title}</h3>
              <p class="pillar-desc">{p.desc}</p>
            </div>
            <a href={p.href} class="pillar-cta" aria-label={`Go to ${p.title}`}>
              {p.cta} →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       TRAINING LOG PREVIEW
  ══════════════════════════════════════════════════════════ -->
  <section class="log-section" aria-labelledby="log-heading">
    <div class="container">
      <p class="section-eyebrow light">Engine Room</p>
      <h2 id="log-heading" class="section-title light">Latest from<br>the logs</h2>

      <ul class="log-list" role="list">
        {logEntries.map((entry) => (
          <li class="log-entry">
            <span class="log-date">{entry.date}</span>
            <span class="log-title">{entry.title}</span>
            <span class={`log-tag tag-${entry.tagColor}`}>{entry.tag}</span>
          </li>
        ))}
      </ul>

      <a href="/engine-room" class="btn btn-outline-light log-more">
        All entries →
      </a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       TAGLINE BLOCK
  ══════════════════════════════════════════════════════════ -->
  <section class="tagline-block" aria-label="Site mission statement">
    <div class="container tagline-inner">
      <h2 class="tagline-headline">
        Your diagnosis<br>is the start line.
      </h2>
      <p class="tagline-sub">
        BX Ultra is built on one idea: that chronic lung disease and
        athletic ambition are not opposites. We aim to maximize our 
		fitness, daily quality of life, and seek adventure.
      </p>
      <a href="/start-here" class="btn btn-forest">Begin the journey →</a>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="BX Ultra home">BX<span>ULTRA</span></a>
        <p class="footer-tagline">Breathe. Push. Repeat.</p>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <a href="/engine-room">Engine Room</a>
        <a href="/lab">The Lab</a>
        <a href="/lifestyle">Lifestyle Hub</a>
        <a href="/basecamp">Basecamp</a>
        <a href="/what-is-bx">What is BX?</a>
        <a href="/about">About</a>
      </nav>

      <div class="footer-social">
        <!-- Replace # with your real URLs when ready -->
        <a href="#" aria-label="Instagram" rel="noopener noreferrer">IG</a>
        <a href="#" aria-label="Discord"   rel="noopener noreferrer">DC</a>
        <a href="#" aria-label="Strava"    rel="noopener noreferrer">ST</a>
      </div>
    </div>

    <p class="footer-legal">
      © {new Date().getFullYear()} BX Ultra · Built by The Airway Adventurer
    </p>
  </footer>

</Layout>

<!-- ════════════════════════════════════════════════════════════
     STYLES  (scoped to this page — won't leak globally)
════════════════════════════════════════════════════════════ -->
<style>

  /* ── NAV ─────────────────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--forest);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 56px;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 24px;
    letter-spacing: 0.03em;
    color: var(--cream);
    text-decoration: none;
  }
  .logo span { color: var(--orange); }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-menu a {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cream80);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-menu a:hover { color: var(--cream); }

  .nav-pill {
    background: var(--orange);
    color: var(--cream) !important;
    padding: 5px 12px;
    border-radius: var(--radius-sm);
  }
  .nav-pill:hover { opacity: 0.9; }

  /* Hamburger — hidden on desktop */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--cream);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* ── TICKER ──────────────────────────────────────────────── */
  .ticker,
  .divider-ticker {
    overflow: hidden;
    white-space: nowrap;
    background: var(--orange);
    padding: 7px 0;
  }
  .ticker-track {
    display: inline-block;
    animation: ticker 28s linear infinite;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream);
  }

  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── HERO ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    background: var(--forest);
    padding: 5rem 2rem 4rem;
    overflow: hidden;
  }

  /* Subtle background grid lines for texture */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(249,248,246,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249,248,246,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  /* Race bib */
  .bib {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: var(--cream);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    text-align: center;
    min-width: 96px;
  }
  .bib-num {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 52px;
    line-height: 1;
    color: var(--orange);
  }
  .bib-label {
    display: block;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--forest);
    margin-top: 4px;
  }

  /* Hero text */
  .hero-eyebrow {
    position: relative;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1rem;
  }

  .hero-headline {
    position: relative;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(52px, 8vw, 80px);
    line-height: 0.93;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--cream);
    max-width: 560px;
    margin-bottom: 1.75rem;
  }
  .hero-headline em {
    font-style: normal;
    color: var(--orange);
  }

  .hero-sub {
    position: relative;
    font-size: 16px;
    line-height: 1.65;
    color: var(--cream80);
    max-width: 440px;
    margin-bottom: 2.25rem;
  }

  /* CTA buttons */
  .hero-ctas {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 3rem;
  }

  .btn {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 12px 24px;
    border-radius: var(--radius-sm);
    transition: opacity 0.15s, transform 0.1s;
    cursor: pointer;
  }
  .btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-primary {
    background: var(--orange);
    color: var(--cream);
    border: none;
  }
  .btn-ghost {
    background: transparent;
    color: var(--cream80);
    border: 1.5px solid rgba(249,248,246,0.3);
  }
  .btn-ghost:hover { color: var(--cream); border-color: rgba(249,248,246,0.6); }

  .btn-outline-light {
    background: transparent;
    color: var(--cream80);
    border: 1.5px solid rgba(249,248,246,0.25);
  }
  .btn-outline-light:hover { color: var(--cream); border-color: rgba(249,248,246,0.55); }

  .btn-forest {
    background: var(--forest);
    color: var(--cream);
    border: none;
  }

  /* Hero stats */
  .hero-stats {
    position: relative;
    display: flex;
    gap: 2.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--cream15);
  }
  .stat-val {
    display: block;
    font-family: var(--font-display);
    font-size: 38px;
    font-weight: 700;
    color: var(--cream);
    line-height: 1;
  }
  .stat-label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--cream50);
    margin-top: 4px;
  }

  /* ── SHARED SECTION STYLES ───────────────────────────────── */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-eyebrow {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.4rem;
  }
  .section-eyebrow.light { color: rgba(230, 92, 0, 0.9); }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 48px);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.95;
    color: var(--forest);
    margin-bottom: 2.25rem;
  }
  .section-title.light { color: var(--cream); }

  /* ── PILLARS ─────────────────────────────────────────────── */
  .pillars-section {
    padding: 4rem 0;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .pillar-card {
    background: #fff;
    border-radius: var(--radius-md);
    border: 1px solid var(--forest15);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .pillar-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--orange);
    border-radius: var(--radius-md) var(--radius-md) 0 0;
  }
  .pillar-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(30, 63, 32, 0.08);
  }

  .pillar-card-top { margin-bottom: 1.25rem; }

  .pillar-num {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--forest60);
    display: block;
    margin-bottom: 0.4rem;
  }
  .pillar-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--forest);
    margin-bottom: 0.6rem;
  }
  .pillar-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--forest60);
  }

  .pillar-cta {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1.5px solid var(--orange);
    padding-bottom: 1px;
    align-self: flex-start;
    transition: opacity 0.15s;
  }
  .pillar-cta:hover { opacity: 0.7; }

  /* ── LOG SECTION ─────────────────────────────────────────── */
  .log-section {
    background: var(--forest);
    padding: 4rem 0;
  }

  .log-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .log-entry {
    background: var(--cream10);
    border: 1px solid var(--cream15);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition: background 0.15s;
  }
  .log-entry:hover { background: rgba(249,248,246,0.09); }

  .log-date {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--orange);
    min-width: 52px;
    flex-shrink: 0;
  }
  .log-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--cream);
    flex: 1;
  }
  .log-tag {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .tag-green  { background: rgba(100, 180, 100, 0.15); color: #7ecf7e; }
  .tag-teal   { background: rgba( 80, 180, 180, 0.15); color: #6dcfcf; }
  .tag-orange { background: rgba(230,  92,   0, 0.18); color: var(--orange); }

  .log-more { margin-top: 0.5rem; }

  /* ── TAGLINE BLOCK ───────────────────────────────────────── */
  .tagline-block {
    background: var(--orange);
    padding: 5rem 2rem;
    text-align: center;
  }
  .tagline-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .tagline-headline {
    font-family: var(--font-display);
    font-size: clamp(44px, 7vw, 68px);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.95;
    color: var(--cream);
    letter-spacing: -0.01em;
  }
  .tagline-sub {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(249,248,246,0.82);
    max-width: 400px;
  }

  /* ── FOOTER ──────────────────────────────────────────────── */
  .footer {
    background: var(--forest);
    border-top: 3px solid var(--orange);
    padding: 2.5rem 2rem 1.5rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer-brand { flex: 1; min-width: 140px; }
  .footer-brand .logo { font-size: 20px; display: inline-block; margin-bottom: 6px; }
  .footer-tagline {
    font-size: 12px;
    color: var(--cream50);
    letter-spacing: 0.04em;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    flex: 2;
  }
  .footer-nav a {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--cream50);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--cream); }

  .footer-social {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--cream15);
    border-radius: 50%;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--cream50);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }
  .footer-social a:hover { color: var(--cream); border-color: var(--cream50); }

  .footer-legal {
    font-size: 12px;
    color: rgba(249,248,246,0.3);
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--cream10);
  }

  /* ── RESPONSIVE ──────────────────────────────────────────── */
  @media (max-width: 700px) {
    /* Nav */
