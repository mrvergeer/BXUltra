---
// src/pages/about.astro
// BX Ultra — About page
// Structure: Nav → Page hero → Story (2-col) → Timeline → Manifesto → Site pillars CTA → Footer
import Layout from '../layouts/Layout.astro';

// ── Timeline entries — edit these as your story grows ──────────────────────────
const timeline = [
  {
    body:  "I am an adventurer, a parent, and a patient, <strong>but I am not a doctor.</strong> I do my absolute best to source all information on BXUltra from reliable, verified medical research. However, everything here is for informational and motivational purposes. For any medical issues, decisions, or questions, please always consult with a qualified medical professional.",
    accent: true,
  },
];

// ── Values — the three things this site stands for ────────────────────────────
const values = [
  {
    num:   "I",
    title: "Evidence Based",
    body:  "Cutting through the dense medical jargon to help you truly understand the disease, how it impacts you, and what to expect.",
  },
  {
    num:   "II",
    title: "Lifestyle Optimization",
    body:  "Exploring actionable ways to tweak your daily habits, feel your absolute best, and actively work to slow the progression of the disease.",
  },
  {
    num:   "III",
    title: "Audacious Goals",
    body:  "Inspiring each other to set massive physical targets that others might think are impossible for people with lung conditions. I’m setting big goals for myself, and I want you to chase yours right alongside me.",
  },
  {
    num:   "IV",
    title: "A Fearless Community",
    body:  "Creating a space to connect, share raw experiences, swap tips, and lift each other up so we can live deeply full, active lives.",
  },
];
---

<Layout
  title="About"
  description="The story behind BX Ultra — a 41-year-old with bronchiectasis training toward ultra-endurance goals, and building a community for others with chronic lung conditions."
>

  <!-- ══════════════════════════════════════════════════════════
       NAV  (identical across all pages)
  ══════════════════════════════════════════════════════════ -->
  <header class="nav">
    <a href="/" class="logo" aria-label="BX Ultra home">BX<span>ULTRA</span></a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    <nav id="nav-menu" class="nav-menu" role="navigation" aria-label="Main">
      <a href="/engine-room">Engine Room</a>
      <a href="/lab">The Lab</a>
      <a href="/lifestyle">Lifestyle Hub</a>
      <a href="/basecamp">Basecamp</a>
	  <a href="/about">About Me</a>
      <a href="/what-is-bx" class="nav-pill">What is BX?</a>
    </nav>
  </header>

  <!-- ══════════════════════════════════════════════════════════
       PAGE HERO  — quieter than homepage, text-led
  ══════════════════════════════════════════════════════════ -->
  <section class="page-hero" aria-labelledby="about-heading">
    <div class="container">
      <p class="page-eyebrow">About</p>
      <h1 id="about-heading" class="page-headline">
        The Airway<br><em>Adventurer</em>
      </h1>
      <p class="page-sub">
        A 41-year-old parent with bronchiectasis, choosing a full 
		life over a restricted one. This platform is a roadmap and 
		a community for anyone refusing to let damaged lungs shrink 
		their boundaries. Here, we don’t just manage a condition. 
		We boldly chase the adventures, big and small, that make 
		life worth living.
      </p>
    </div>

    <!-- Decorative rule with orange accent -->
    <div class="hero-rule" aria-hidden="true">
      <span class="rule-line"></span>
      <span class="rule-dot"></span>
      <span class="rule-line"></span>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       STORY  — two-column longread layout
  ══════════════════════════════════════════════════════════ -->
  <section class="story-section" aria-labelledby="story-heading">
    <div class="container story-grid">

      <!-- Sticky sidebar label -->
      <aside class="story-aside" aria-hidden="true">
        <span class="aside-label">The Story</span>
        <div class="aside-line"></div>
      </aside>

      <!-- Main narrative -->
      <div class="story-body">
        <h2 id="story-heading" class="story-heading">
          My Story: From Denial to Defiance
        </h2>
		<p>
		  In 2015, at 31 years old, I sat in an Irish hospital bed and listened to a 
		  doctor tell me I had Bronchiectasis.
		</p>

        <p>
          Because of my age, the doctors called it unusual. Because of the uncertainty, 
		  the exact cause remained a mystery, though strong indicators pointed to 
		  a perfect storm of acid reflux and heavy alcohol consumption. It was a 
		  lot to take in. So, honestly? I didn’t take it seriously. Even as doctors 
		  reconfirmed the diagnosis in the years that followed, I convinced myself 
		  it would just blow over.
        </p>

        <p>
          Growing up, my body was my baseline. I was always active—playing team sports 
		  as a kid, and moving into cycling, running, surfing, and snowboarding as I 
		  got older. I wasn’t a pro athlete, but my fitness was uncompromised. I took 
		  for granted the natural, logical assumption that your body will always 
		  cooperate with your ambitions.
        </p>

        <blockquote class="pull-quote">
          "Then reality caught up. The disease is real. </br>
		  But the limits are negotiable."
        </blockquote>

        <p>
          In recent years, the denial faded, replaced by real concern. Part of it was 
		  becoming a parent. Part of it was the undeniable physical toll: the endless 
		  coughing, the draining fatigue, and the frustrating realization that things 
		  weren't getting better on their own. I realized I had a choice: let this 
		  condition dictate the boundaries of my life, or face it head-on to maximize 
		  the time, energy, and adventures I have left.
        </p>

        <p>
          If you've just been diagnosed and you're trying to make sense of what your life
          looks like now — <a href="/what-is-bx" class="inline-link">start here</a>.
          If you're already training and you want data, community, and company —
          <a href="/engine-room" class="inline-link">come into the Engine Room</a>.
          Either way: you're not alone in this, and you found the right place.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       TIMELINE
  ══════════════════════════════════════════════════════════ -->
  <section class="timeline-section" aria-labelledby="timeline-heading">
    <div class="container">
      <p class="section-eyebrow">Acknowledgement</p>
      <h2 id="timeline-heading" class="section-title">A Note from the Founder</h2>

      
        {timeline.map((item, i) => (
    <div class="timeline-content">
      <p class="timeline-body" set:html={item.body} />
    </div>
	))}
      
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       VALUES / MANIFESTO  — forest background
  ══════════════════════════════════════════════════════════ -->
  <section class="values-section" aria-labelledby="values-heading">
    <div class="container">
      <p class="section-eyebrow light">The BXUltra Mission</p>
      <h2 id="values-heading" class="section-title light">Four commitments</h2>

      <div class="values-grid">
        {values.map((v) => (
          <article class="value-card">
            <span class="value-num" aria-hidden="true">{v.num}</span>
            <h3 class="value-title">{v.title}</h3>
            <p class="value-body">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       CTA STRIP — where to go next
  ══════════════════════════════════════════════════════════ -->
  <section class="cta-strip" aria-label="Where to go next">
    <div class="container cta-strip-inner">
      <div class="cta-strip-text">
        <h2 class="cta-strip-headline">Ready to explore?</h2>
        <p class="cta-strip-sub">Pick a section and start where it makes sense for you.</p>
      </div>
      <div class="cta-strip-buttons">
        <a href="/start-here"   class="btn btn-primary">Start Here ↗</a>
        <a href="/what-is-bx"  class="btn btn-ghost-dark">What is BX?</a>
        <a href="/engine-room" class="btn btn-ghost-dark">Training Logs</a>
        <a href="/basecamp"    class="btn btn-ghost-dark">Community</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="BX Ultra home">BX<span>ULTRA</span></a>
        <p class="footer-tagline">Breathe. Push. Repeat.</p>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <a href="/engine-room">Engine Room</a>
        <a href="/lab">The Lab</a>
        <a href="/lifestyle">Lifestyle Hub</a>
        <a href="/basecamp">Basecamp</a>
        <a href="/what-is-bx">What is BX?</a>
        <a href="/about">About</a>
      </nav>

      <div class="footer-social">
        <a href="#" aria-label="Instagram" rel="noopener noreferrer">IG</a>
        <a href="#" aria-label="Discord"   rel="noopener noreferrer">DC</a>
        <a href="#" aria-label="Strava"    rel="noopener noreferrer">ST</a>
      </div>
    </div>
    <p class="footer-legal">
      © {new Date().getFullYear()} BX Ultra · Built by The Airway Adventurer
    </p>
  </footer>

</Layout>

<!-- ════════════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════════════ -->
<style>

  /* ── NAV ─────────────────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--forest);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 56px;
  }
  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 24px;
    letter-spacing: 0.03em;
    color: var(--cream);
    text-decoration: none;
  }
  .logo span { color: var(--orange); }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-menu a {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cream80);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-menu a:hover,
  .nav-menu a[aria-current="page"] { color: var(--cream); }

  /* Highlight the current page link */
  .nav-menu a[href="/about"] { color: var(--cream); border-bottom: 1.5px solid var(--orange); padding-bottom: 2px; }

  .nav-pill {
    background: var(--orange);
    color: var(--cream) !important;
    padding: 5px 12px;
    border-radius: var(--radius-sm);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 22px;
    height: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--cream);
    border-radius: 1px;
  }

  /* ── SHARED UTILITIES ────────────────────────────────────── */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-eyebrow {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.4rem;
  }
  .section-eyebrow.light { color: rgba(230, 92, 0, 0.9); }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 48px);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.95;
    color: var(--forest);
    margin-bottom: 2.5rem;
  }
  .section-title.light { color: var(--cream); }

  /* ── BUTTONS ─────────────────────────────────────────────── */
  .btn {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 11px 22px;
    border-radius: var(--radius-sm);
    transition: opacity 0.15s, transform 0.1s;
    white-space: nowrap;
  }
  .btn:hover  { opacity: 0.85; transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  .btn-primary    { background: var(--orange); color: var(--cream); border: none; }
  .btn-ghost-dark { background: transparent; color: var(--forest); border: 1.5px solid var(--forest15); }
  .btn-ghost-dark:hover { border-color: var(--forest); }

  /* ── PAGE HERO ───────────────────────────────────────────── */
  .page-hero {
    background: var(--forest);
    padding: 4.5rem 0 0;
  }
  .page-hero .container { padding-bottom: 3.5rem; }

  .page-eyebrow {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 0.75rem;
  }

  .page-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(52px, 8vw, 80px);
    line-height: 0.93;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--cream);
    margin-bottom: 1.5rem;
  }
  .page-headline em { font-style: normal; color: var(--orange); }

  .page-sub {
    font-size: 17px;
    line-height: 1.65;
    color: var(--cream80);
    max-width: 520px;
  }

  /* Decorative rule at the bottom of page hero */
  .hero-rule {
    display: flex;
    align-items: center;
    padding: 0 2rem;
    gap: 0;
  }
  .rule-line {
    flex: 1;
    height: 3px;
    background: var(--orange);
  }
  .rule-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--cream);
    border: 2px solid var(--orange);
    flex-shrink: 0;
  }

  /* ── STORY SECTION ───────────────────────────────────────── */
  .story-section {
    padding: 5rem 0;
    background: var(--cream);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .story-aside {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding-top: 6px;
  }
  .aside-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--orange);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }
  .aside-line {
    width: 2px;
    flex: 1;
    min-height: 80px;
    background: var(--forest15);
    margin-left: 4px;
  }

  .story-body {
    max-width: 640px;
  }

  .story-heading {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 38px);
    font-weight: 900;
    text-transform: uppercase;
    color: var(--forest);
    margin-bottom: 1.75rem;
    line-height: 1;
  }

  .story-body p {
    font-size: 17px;
    line-height: 1.75;
    color: var(--forest);
    margin-bottom: 1.25rem;
  }
  .story-body p em { font-style: italic; }

  .pull-quote {
    border-left: 3px solid var(--orange);
    padding: 0.75rem 0 0.75rem 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.2;
    color: var(--forest);
  }

  .inline-link {
    color: var(--orange);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 500;
    transition: opacity 0.15s;
  }
  .inline-link:hover { opacity: 0.75; }

  /* ── TIMELINE ────────────────────────────────────────────── */
  .timeline-section {
    padding: 4rem 0 5rem;
    background: #f0eeeb; /* slightly darker than cream for contrast */
  }

  .timeline {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 1.25rem;
    position: relative;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 5px;
  }

  .marker-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--forest15);
    border: 2px solid var(--forest);
    flex-shrink: 0;
    z-index: 1;
  }
  .timeline-item--accent .marker-dot {
    background: var(--orange);
    border-color: var(--orange);
  }

  .marker-line {
    width: 2px;
    flex: 1;
    min-height: 32px;
    background: var(--forest15);
    margin-top: 4px;
  }

  .timeline-content {
    padding-bottom: 2.5rem;
  }

  .timeline-year {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--orange);
    display: block;
    margin-bottom: 0.3rem;
  }

  .timeline-label {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--forest);
    margin-bottom: 0.5rem;
  }

  .timeline-body {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(30, 63, 32, 0.7);
    max-width: 540px;
  }

  .timeline-body :global(strong) {
  color: var(--orange) !important;
  font-weight: 800;     
  font-size: 17px;
  }

  /* ── VALUES ──────────────────────────────────────────────── */
  .values-section {
    background: var(--forest);
    padding: 4.5rem 0;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .value-card {
    border-top: 2px solid var(--cream15);
    padding-top: 1.5rem;
  }

  .value-num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 900;
    color: var(--orange);
    opacity: 0.5;
    display: block;
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .value-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--cream);
    margin-bottom: 0.75rem;
  }

  .value-body {
    font-size: 14px;
    line-height: 1.7;
    color: var(--cream80);
  }

  /* ── CTA STRIP ───────────────────────────────────────────── */
  .cta-strip {
    background: var(--cream);
    border-top: 1px solid var(--forest15);
    border-bottom: 1px solid var(--forest15);
    padding: 3rem 0;
  }

  .cta-strip-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
    justify-content: space-between;
  }

  .cta-strip-headline {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--forest);
    margin-bottom: 0.25rem;
  }

  .cta-strip-sub {
    font-size: 14px;
    color: var(--forest60);
  }

  .cta-strip-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  /* ── FOOTER ──────────────────────────────────────────────── */
  .footer {
    background: var(--forest);
    border-top: 3px solid var(--orange);
    padding: 2.5rem 2rem 1.5rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer-brand { flex: 1; min-width: 140px; }
  .footer-brand .logo { font-size: 20px; display: inline-block; margin-bottom: 6px; }
  .footer-tagline { font-size: 12px; color: var(--cream50); letter-spacing: 0.04em; }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    flex: 2;
  }
  .footer-nav a {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--cream50);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--cream); }
  .footer-nav a[href="/about"] { color: var(--cream); }

  .footer-social { display: flex; gap: 10px; align-items: center; }
  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--cream15);
    border-radius: 50%;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--cream50);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }
  .footer-social a:hover { color: var(--cream); border-color: var(--cream50); }

  .footer-legal {
    font-size: 12px;
    color: rgba(249,248,246,0.3);
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid var(--cream10);
  }

  /* ── RESPONSIVE ──────────────────────────────────────────── */
  @media (max-width: 760px) {
    /* Nav */
    .nav-toggle { display: flex; }
    .nav-menu {
      display: none;
      position: absolute;
      top: 56px;
      left: 0; right: 0;
      background: var(--forest);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 0.5rem 0 1rem;
      border-top: 1px solid var(--cream15);
    }
    .nav-menu.open { display: flex; }
    .nav-menu a { width: 100%; padding: 0.75rem 2rem; font-size: 14px; }
    .nav-menu a[href="/about"] { border-bottom: none; padding-bottom: 0.75rem; }
    .nav-pill { border-radius: 0; background: transparent; color: var(--orange) !important; }

    /* Story: collapse to single column */
    .story-grid { grid-template-columns: 1fr; gap: 0; }
    .story-aside { display: none; }
    .story-body p { font-size: 16px; }

    /* Values: stack */
    .values-grid { grid-template-columns: 1fr; gap: 2rem; }

    /* CTA strip */
    .cta-strip-inner { flex-direction: column; align-items: flex-start; }

    /* Footer */
    .footer-inner { flex-direction: column; gap: 1.5rem; }
    .footer-nav { gap: 0.4rem 1rem; }
  }
</style>

<!-- ════════════════════════════════════════════════════════════
     MOBILE NAV TOGGLE
════════════════════════════════════════════════════════════ -->
<script>
  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const menu   = document.querySelector('.nav-menu')   as HTMLElement;

  toggle?.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>